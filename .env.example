# === Xray (Reality) ===
# Generate with: xray x25519
XRAY_REALITY_PRIVATE_KEY=CHANGE_ME
XRAY_REALITY_DEST=steamcommunity.com:443
# XRAY_REALITY_SERVER_NAMES выводится из DEST автоматически. Переопределите если нужно:
# XRAY_REALITY_SERVER_NAMES=steamcommunity.com
XRAY_REALITY_SHORT_IDS=cbdc51eb,7ae88f24,f3116322,94571650,92e2b18e,a38c78ef
XRAY_LOG_LEVEL=warning

# Clients: semicolon-separated, each id,name (name optional)
# Name goes after # in VLESS URL — shown as connection title in client app
# Format: "uuid1,name1;uuid2,name2;uuid3"
XRAY_CLIENTS=CHANGE_ME

# === Nginx (Front) ===
DECOY_DOMAIN=example.com
DECOY_TITLE=IT Consultancy — Example Corp
DECOY_HTML_DIR=./nginx/html

# === Ports ===
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# === SSL ===
# Directory for cert files. LE deploy hook copies here, nginx reloads on SIGHUP.
# Leave as ./ssl — self-signed baked into Docker image as fallback.
SSL_DIR=./ssl
